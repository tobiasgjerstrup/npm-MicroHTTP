{
  "name": "@tobiasgjerstrup/microhttp",
  "version": "1.3.1",
  "description": "A small wrapper for nodejs' http",
  "homepage": "https://github.com/tobiasgjerstrup/npm-MicroHTTP#readme",
  "bugs": {
    "url": "https://github.com/tobiasgjerstrup/npm-MicroHTTP/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasgjerstrup/npm-MicroHTTP.git"
  },
  "license": "ISC",
  "author": "Tobias Gjerstrup",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "cd playground && npm start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "prepublishOnly": "npm run build && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tobiasgjerstrup/microhttp-server": "1.2.0",
    "@types/node": "25.6.0",
    "eslint": "10.2.0",
    "globals": "17.5.0",
    "jiti": "2.6.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4"
  }
}
